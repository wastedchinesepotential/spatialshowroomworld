{
    "name": "@evercoast/three",
    "version": "2.3.1",
    "description": "Evercoast ThreeJS integration",
    "type": "module",
    "main": "./dist/evercoast-three.js",
    "files": [
        "./dist/evercoast-*",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc && vite build && npm run api",
        "dev": "concurrently \"vite build -w\" \"vite --host\"",
        "api": "tsx ../../scripts/gen-api.ts",
        "lint": "eslint ./src/",
        "pack": "npm pack --pack-destination ./../../releases",
        "clean": "rimraf dist types"
    },
    "exports": {
        "import": {
            "types": "./dist/evercoast-three.d.ts",
            "default": "./dist/evercoast-three.js"
        },
        "require": {
            "types": "./dist/evercoast-three.umd.d.ts",
            "default": "./dist/evercoast-three.umd.cjs"
        }
    },
    "keywords": [],
    "author": {
        "name": "Evercoast",
        "email": "support@evercoast.com",
        "url": "https://support.evercoast.com/docs/web-player-sdk-overview"
    },
    "license": "MIT",
    "peerDependencies": {
        "three": "*"
    }
}
